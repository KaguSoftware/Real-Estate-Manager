# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: required by /api/admin/users
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Canonical deployed URL. Auth emails (confirm / magic link) link back to
# `${NEXT_PUBLIC_SITE_URL}/auth/callback`, so sign-ups made from a dev session
# still produce links that work from a real inbox. Also set the same value as
# "Site URL" in Supabase Dashboard → Authentication → URL Configuration, and
# add https://YOUR_DOMAIN/auth/callback + http://localhost:3000/auth/callback
# to the Redirect URLs allowlist there.
NEXT_PUBLIC_SITE_URL=https://your-production-domain.com

# Contact email sent with OSM Nominatim geocoding requests (their usage policy).
NOMINATIM_EMAIL=you@example.com

# Billing — 'iyzico' (default, stub until wired) or 'mock' (dev/E2E: instantly
# activates a subscription via a synthetic webhook; blocked in production).
BILLING_PROVIDER=mock
# Iyzico credentials (sandbox: https://sandbox-api.iyzipay.com)
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
