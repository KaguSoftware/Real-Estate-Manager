# Copy to .env.local and fill in. Never commit .env.local (it is gitignored).
# Values live in Supabase Dashboard → Settings → API, plus your own config.

# --- Supabase (public — safe to expose to the browser) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Canonical app URL (CRITICAL for auth) ---
# Every auth email link, OAuth/callback redirect and invite link is built from
# this. It MUST match the Supabase "Site URL" + Redirect URLs allowlist, or
# emails fall back to Supabase's Site URL (historically http://localhost:3000).
# NEXT_PUBLIC_* is inlined at BUILD time — set it in Vercel (Production + Preview)
# and redeploy for changes to take effect.
NEXT_PUBLIC_SITE_URL=https://kagu-realestate.com

# --- Supabase service role (server-only — NEVER expose to the browser) ---
# Must decode to "role":"service_role" (not "anon"). Used by invite emails,
# admin panel, billing webhook, account deletion, trial cron.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Cron ---
# Any long random string (e.g. `openssl rand -hex 32`); Vercel sends it with the
# daily /api/cron/trial-check job.
CRON_SECRET=

# --- Billing ---
BILLING_PROVIDER=iyzico
# IYZICO_API_KEY=
# IYZICO_SECRET_KEY=
# IYZICO_BASE_URL=

# --- Rate limiting (optional; Upstash Redis for cross-instance limits) ---
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Sentry (optional) ---
# NEXT_PUBLIC_SENTRY_DSN=
