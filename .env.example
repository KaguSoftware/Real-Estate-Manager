# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: required by /api/admin/users
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Canonical deployed URL. Auth emails (confirm / magic link) link back to
# `${NEXT_PUBLIC_SITE_URL}/auth/callback`, so sign-ups made from a dev session
# still produce links that work from a real inbox. Also set the same value as
# "Site URL" in Supabase Dashboard → Authentication → URL Configuration, and
# add https://YOUR_DOMAIN/auth/callback + http://localhost:3000/auth/callback
# to the Redirect URLs allowlist there.
NEXT_PUBLIC_SITE_URL=https://your-production-domain.com

# Contact email sent with OSM Nominatim geocoding requests (their usage policy).
NOMINATIM_EMAIL=you@example.com

# Billing — 'iyzico' (default, stub until wired) or 'mock' (dev/E2E: instantly
# activates a subscription via a synthetic webhook). 'mock' is HARD-BLOCKED in
# production regardless of this value; use it only locally.
BILLING_PROVIDER=iyzico
# Iyzico credentials (sandbox: https://sandbox-api.iyzipay.com)
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Rate limiting (optional). Without these the limiter falls back to per-instance
# in-memory counting. Provision via Vercel Marketplace → Upstash Redis.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Error monitoring. Optional: overrides the default DSN baked into
# sentry.*.config.ts / instrumentation-client.ts; set to an empty string to
# disable Sentry entirely for an environment. CI source-map uploads use
# SENTRY_AUTH_TOKEN, which lives in the gitignored .env.sentry-build-plugin —
# add it to your CI/Vercel env.
# NEXT_PUBLIC_SENTRY_DSN=

# Daily trial-reminder cron (/api/cron/trial-check). Set any long random string
# and configure the same value as the cron secret on Vercel.
CRON_SECRET=
